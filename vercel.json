{
  "version": 2,
  "framework": null,
  "outputDirectory": ".",
  "buildCommand": "",
  "devCommand": "npx serve . -l $PORT",
  "rewrites": [
    { "source": "/api/github",     "destination": "/api/github.js" },
    { "source": "/api/gsoc-guide", "destination": "/api/gsoc-guide.js" }
  ],
  "headers": [
    {
      "source": "/api/gsoc-guide",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/api/github",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/data/(.*)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}